{
  "version": 2,
  "builds": [
    { "src": "landing/index.html", "use": "@vercel/static" },
    { "src": "landing/styles.css", "use": "@vercel/static" },
    { "src": "samples/01_outbound_mexico_fintech_cmo.mp3", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/landing/index.html" },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "SAMEORIGIN",
        "Referrer-Policy": "strict-origin-when-cross-origin"
      }
    }
  ]
}
