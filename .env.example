# Copy this to .env and fill in your real values.

# Required: get from elevenlabs.io dashboard → Profile → API Keys
ELEVENLABS_API_KEY=your_key_here

# Optional: defaults to Sarah (multilingual library voice).
# Use a Spanish-MX voice from your library for higher fidelity.
# AGENT_VOICE_ID=

# Optional: low-latency model for conversation (default: eleven_flash_v2_5)
# AGENT_MODEL_ID=

# Optional: LLM for the agent (default: gemini-2.0-flash)
# AGENT_LLM=

# Optional: model for the bonus TTS MP3 (default: eleven_multilingual_v2)
# TTS_MODEL_ID=
